  <footer>
    <h2>Beginning Reports</h2>
    <p>When logged in to <a href="https://adsmanager.facebook.com/adsmanager/manage/accounts?act=973460868056419&business_id=544065836936392#">Meta Ads Manager</a> with the <strong>Rula Diab</strong> Facebook account, you can view a <a href="https://adsmanager.facebook.com/adsmanager/reporting/business_view?act=973460868056419&business_id=544065836936392&selected_report_id=1334356347907333">rough report</a> of Meta Ads spend and leads aquired. We also put together a simple line graph view of the <a href="https://adsmanager.facebook.com/adsmanager/reporting/business_view?act=973460868056419&business_id=544065836936392&selected_report_id=1369638981045736">number of leads &amp; price per lead</a>, defaulting to monthly in order to clearly show the increasing number of leads and decreasing price of each over time. 🚀</p>
  </footer>
  <script>
    // Get all article.card elements
    const cards = document.querySelectorAll('article.card');

    // Mark running cards
    cards.forEach((card, index) => {
      const position = index + 1;
      if (runningIndices.includes(position)) {
        card.classList.add('running');
      }
    });

    // Create and insert the toggle button
    const toggleBtn = document.createElement('button');
    toggleBtn.id = 'toggle-running-btn';
    toggleBtn.textContent = 'Show Only Running';
    toggleBtn.classList.add('toggle-btn');

    const header = document.querySelector('header');
    header.insertAdjacentElement('beforeend', toggleBtn);

    // Toggle functionality
    let showingOnlyRunning = false;
    toggleBtn.addEventListener('click', () => {
      showingOnlyRunning = !showingOnlyRunning;

      cards.forEach(card => {
        const isRunning = card.classList.contains('running');
        card.classList.toggle('hidden', showingOnlyRunning && !isRunning);
      });

      toggleBtn.textContent = showingOnlyRunning ? 'Show All' : 'Show Only Running';
    });
    document.querySelectorAll('.status-dot').forEach(dot => {
      // Set initial title
      dot.title = 'not running';

      // Find the nearest ancestor with class 'card'
      const card = dot.closest('article.card');

      if (!card) return; // No ancestor found, skip

      dot.addEventListener('mouseenter', () => {
        if (card.classList.contains('running')) {
          dot.title = 'running';
        }
      });

      dot.addEventListener('mouseleave', () => {
        dot.title = 'not running';
      });
    });
    document.querySelectorAll('a[href=""]').forEach(anchor => {
      anchor.addEventListener('click', function(event) {
        event.preventDefault();
        alert('Link not yet available');
      });
    });
  </script>
</body>
